# 07-UTE — Layout feature flags (UI chrome only, mock/demo)
#
# Dev server: http://localhost:5107 (vite.config.ts · strictPort, no fallback)
#
# PUBLIC TEMPLATE ONLY — safe to commit. Copy to `.env.local` for your machine:
#   cp .env.example .env.local   (then uncomment overrides you need)
#
# `.env.local` and `.env.*.local` are gitignored — never commit them.
# Store real API keys / broker secrets only in `.env.local` or a secret manager, never here.
#
# SECURITY: Do NOT put API keys, broker secrets, or live trading credentials in this file.
# These variables only affect layout visibility — not order routing or adapters.
#
# Boolean: true | false | 1 | 0 | yes | no | on | off (see layoutFeatureFlags.ts)
# Omit any key to use in-code defaults (recommended for normal demo).

# --- Layout preset (unknown value → hts) ---
# Options: hts | simple | mobile | compact | tournament
# Default: (omit) → hts
# Recommended demo: hts
# VITE_UTE_LAYOUT_PRESET=hts

# --- Safety / mode ---
# Default: false | Recommended demo: false
# VITE_UTE_EMERGENCY_DISABLE=false
# VITE_UTE_READ_ONLY=false
# Alias: VITE_UTE_READONLY (same as READ_ONLY)

# --- Premium shell chrome ---
# Default: true | Recommended demo: true (full UTE shell)
# VITE_UTE_SHOW_PREMIUM_SHELL=true
# VITE_UTE_SHOW_HTS_TOPBAR=true
# VITE_UTE_SHOW_MARKET_DECK=true
# VITE_UTE_SHOW_SIDEBAR=true
# VITE_UTE_SHOW_BOTTOM_DOCK=true
# VITE_UTE_SHOW_INTEGRATION_SLOTS=true
# Platform header mock notification summary (no push/WebSocket)
# VITE_UTE_SHOW_NOTIFICATION_SLOT=true
# Unified event feed under notification slot (localStorage max 10, mock)
# VITE_UTE_SHOW_UNIFIED_EVENT_FEED=true
# Workspace context router (feed → panel highlight, mock)
# VITE_UTE_ENABLE_WORKSPACE_CONTEXT_ROUTER=true
# 12-TGX-TokenAdmin tenant validation bridge (read-only mock, localStorage)
# VITE_UTE_ENABLE_TENANT_CONTEXT_BRIDGE=true
# Cross-app Global Diagnostics Center on /admin (mock aggregate, in-memory)
# VITE_UTE_ENABLE_GLOBAL_DIAGNOSTICS_CENTER=true
# AI Incident Review board on /admin (mock triage, no auto-remediation)
# VITE_UTE_ENABLE_INCIDENT_REVIEW=true
# VITE_UTE_ENABLE_INCIDENT_AI_SUMMARY=true
# AI Proposal Queue on /admin (mock, status-only review)
# VITE_UTE_ENABLE_PROPOSAL_QUEUE=true
# VITE_UTE_ENABLE_PROPOSAL_AI_SUMMARY=true
# Cross-app risk graph on /admin (mock visualization)
# VITE_UTE_ENABLE_RISK_GRAPH=true
# Global operations timeline on /admin (mock chronological)
# VITE_UTE_ENABLE_OPERATIONS_TIMELINE=true
# VITE_UTE_TENANT_VALIDATION_MOCK_VERDICT=PASS
# VITE_UTE_TENANT_VALIDATION_MOCK_FAIL=false

# --- Partner integration chrome (display only; master: SHOW_INTEGRATION_SLOTS) ---
# Default / recommended demo: see table in docs/UTE_LAYOUT_FEATURE_FLAGS.md § Phase 6
# VITE_UTE_ONEAI_CHROME=true
# VITE_UTE_MOCKINVEST_CHROME=true
# VITE_UTE_GAMEHUB_CHROME=false
# VITE_UTE_TGX_CEX_STRIP=true
# VITE_UTE_SPEEDORDER_CHROME=true

# --- Example profiles (uncomment one block only) ---

# Safe mode (minimal chrome, no integration badges, no bottom dock)
# VITE_UTE_EMERGENCY_DISABLE=true

# Read-only demo (order panel UI disabled)
# VITE_UTE_READ_ONLY=true

# Minimal shell (trading grid only, no premium wrapper / top bar)
# VITE_UTE_SHOW_PREMIUM_SHELL=false
# VITE_UTE_SHOW_HTS_TOPBAR=false
